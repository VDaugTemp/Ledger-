# Copy to .env.local and fill in your values

# OpenAI — used by /api/chat
# Without this, the chat runs in mock mode (no real AI, no cost)
OPENAI_API_KEY=sk-...

# Optional: Vercel AI Gateway key (replaces per-provider keys)
# Get one free at https://vercel.com/~/ai/api-keys ($5/month free credit)
# AI_GATEWAY_API_KEY=...
