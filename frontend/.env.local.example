# Feature flag: set to "false" to use real backend
NEXT_PUBLIC_USE_MOCK_API=false

# Real backend base URL (API Gateway)
NEXT_PUBLIC_COGNITO_API_BASE_URL=https://xxx.execute-api.eu-west-2.amazonaws.com/dev

# Cognito (App Client — public, no secret required)
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_app_client_id
NEXT_PUBLIC_COGNITO_REGION=eu-west-2

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://your-domain.com

# Cognito callback URIs to configure in AWS Console:
#   Allowed callback URLs: http://localhost:3000, https://your-domain.com
#   Allowed sign-out URLs: http://localhost:3000/auth/signed-out, https://your-domain.com/auth/signed-out
